# Starry-Lyfe v7.1 Environment Configuration
# Copy to .env and fill in values

# API (Phase 7 HTTP service on port 8001)
STARRY_LYFE__API__HOST=0.0.0.0
STARRY_LYFE__API__PORT=8001
# Required on POST /v1/chat/completions; absent → 503 readiness fail.
STARRY_LYFE__API__API_KEY=changeme
# Comma-separated list of CORS origins. Empty disables CORS.
STARRY_LYFE__API__CORS_ORIGINS=
# Default character when no header / inline override / model-field match.
STARRY_LYFE__API__DEFAULT_CHARACTER=adelia
# F3 closure (2026-04-15): when true, /health/ready issues a live HEAD
# probe against the BD-1 provider URL. Set false to skip the network
# call (tests, offline dev).
STARRY_LYFE__API__HEALTH_BD1_PROBE=true
# F1 closure (2026-04-15): Crew-mode multi-speaker cap. Project axiom:
# "Max 3 choices per decision point." Raising this past 4 has no effect
# since only 4 canonical women exist.
STARRY_LYFE__API__CREW_MAX_SPEAKERS=3
# Phase 8 (2026-04-15): LLM relationship evaluator toggle + tuning.
# Set LLM=false to force the heuristic _propose_deltas fallback path.
STARRY_LYFE__API__RELATIONSHIP_EVAL_LLM=true
STARRY_LYFE__API__RELATIONSHIP_EVAL_MAX_TOKENS=200
STARRY_LYFE__API__RELATIONSHIP_EVAL_TEMPERATURE=0.2
# Phase 9 (2026-04-15): inter-woman (internal) evaluator toggle. Reuses
# the Phase 8 MAX_TOKENS and TEMPERATURE above. Set false to force the
# heuristic path across all 6 DyadStateInternal dyads.
STARRY_LYFE__API__INTERNAL_RELATIONSHIP_EVAL_LLM=true

# Database (PostgreSQL + pgvector)
STARRY_LYFE__DB__HOST=localhost
STARRY_LYFE__DB__PORT=5432
STARRY_LYFE__DB__NAME=starry_lyfe
STARRY_LYFE__DB__USER=starry_lyfe
STARRY_LYFE__DB__PASSWORD=changeme

# External: SFW Model Provider (Claude via OpenRouter)
STARRY_LYFE__EXT__SFW_PROVIDER_URL=https://openrouter.ai/api/v1
STARRY_LYFE__EXT__SFW_PROVIDER_KEY=changeme
STARRY_LYFE__EXT__SFW_MODEL=deepseek/deepseek-v3.2

# Embedding (LM Studio — OpenAI-compatible /v1/embeddings)
STARRY_LYFE__EXT__EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5@q5_k_m
STARRY_LYFE__EXT__EMBEDDING_DIMENSION=768
STARRY_LYFE__EXT__EMBEDDING_BASE_URL=http://localhost:1234/v1

# Logging
STARRY_LYFE__LOG__LEVEL=INFO

# Environment
STARRY_LYFE__ENV=development
